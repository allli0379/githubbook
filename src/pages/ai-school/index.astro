---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI学堂 | 人工智能学习资源"
  description="AI学习资源聚合平台，涵盖大语言模型、机器学习、深度学习、Prompt Engineering等前沿AI技术教程。"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 pb-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10
                  border border-purple-500/20 text-purple-400 text-sm font-medium mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-purple-400"></span>
        </span>
        即将上线
      </div>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">
        AI <span class="gradient-text">学堂</span>
      </h1>
      <p class="text-github-muted text-lg max-w-2xl mx-auto">
        系统化的 AI 学习资源平台，从入门到精通，助你掌握人工智能核心技术。
      </p>
    </div>

    <!-- Coming Soon Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {[
        {
          icon: '🤖',
          title: '大语言模型 (LLM)',
          desc: '深入理解 Transformer 架构、GPT 系列模型原理、微调技术与 RAG 应用开发。',
          topics: ['Transformer', 'GPT-4', 'RAG', 'Fine-tuning'],
        },
        {
          icon: '🎨',
          title: 'AI 编程与工具',
          desc: '掌握 Cursor、Claude Code、GitHub Copilot 等 AI 编程工具，提升 10 倍开发效率。',
          topics: ['Claude Code', 'Copilot', 'Prompt Engineering', 'AI Agents'],
        },
        {
          icon: '🔬',
          title: '机器学习实战',
          desc: '从经典算法到前沿论文，通过实际项目掌握 ML/DL 核心技术与最佳实践。',
          topics: ['PyTorch', 'TensorFlow', 'Computer Vision', 'NLP'],
        },
      ].map((course, i) => (
        <div class={`glass-card p-6 animate-fade-in-up opacity-0 stagger-${i + 1}`}>
          <div class="text-4xl mb-4">{course.icon}</div>
          <h3 class="text-white font-semibold text-lg mb-2">{course.title}</h3>
          <p class="text-github-muted text-sm leading-relaxed mb-4">{course.desc}</p>
          <div class="flex flex-wrap gap-1.5">
            {course.topics.map((t) => (
              <span class="tag tag-ai text-[10px]">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Subscribe CTA -->
    <div class="max-w-2xl mx-auto mt-16">
      <div class="glass-card p-8 text-center">
        <h3 class="text-xl font-display font-bold text-white mb-3">
          抢先获取 AI 学习资源
        </h3>
        <p class="text-github-muted text-sm mb-6">
          AI 学堂正在紧锣密鼓地筹备中，届时将提供：
          系统化学习路径、实战项目教程、AI 论文解读、行业大咖分享。
        </p>
        <div class="flex items-center justify-center gap-2 text-brand-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M23 4a6 6 0 00-4.22 1.66A3.99 3.99 0 0012 7.35a3.99 3.99 0 00-6.78-.69A6 6 0 001 4v16a4 4 0 013.65-1.97 4 4 0 013.37 1.68L8 20l.02-.32A4 4 0 0111.37 18a3.99 3.99 0 015.26 0 4 4 0 013.37-1.68A4 4 0 0123 20V4z"/>
          </svg>
          <span class="font-medium">敬请期待</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
