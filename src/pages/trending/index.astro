---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrendingCard from '../../components/TrendingCard.astro';
import { getTrendingData, getRecentPosts } from '../../lib/data';

const trending = await getTrendingData();
const posts = await getRecentPosts();
const updateDate = new Date().toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
});
---

<BaseLayout
  title="GitHub热点 | 每日开源项目趋势排行"
  description={`${updateDate} GitHub Trending Top 10 项目，包含AI、前端、后端、DevOps等热门领域。每日更新，追踪开源技术趋势。`}
>
  <!-- Page Header -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 pb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="tag tag-hot sparkle">🔥 LIVE</span>
      <span class="text-github-muted text-sm">更新于 {updateDate}</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-3">
      GitHub <span class="gradient-text-warm">热点</span> 排行榜
    </h1>
    <p class="text-github-muted text-lg max-w-2xl">
      每日从 GitHub Trending 精选 10 个最受关注的开源项目，
      涵盖 AI/ML、前端框架、后端架构、DevOps 工具等热门领域。
    </p>
  </section>

  <!-- Trending List -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-8">
    {trending.length > 0 ? (
      <div class="space-y-4">
        {trending.map((repo, i) => (
          <TrendingCard repo={repo} rank={i + 1} index={i} />
        ))}
      </div>
    ) : (
      <div class="glass-card p-16 text-center">
        <div class="text-5xl mb-4">📡</div>
        <h3 class="text-white text-xl font-semibold mb-2">暂无数据</h3>
        <p class="text-github-muted mb-4">
          请运行 <code class="text-brand-primary bg-github-bg px-2 py-0.5 rounded">npm run fetch-trending</code> 获取最新 GitHub Trending 数据
        </p>
        <div class="text-github-muted text-sm">
          GitHub Actions 将在部署时自动运行数据抓取
        </div>
      </div>
    )}
  </section>

  <!-- Blog Posts -->
  {posts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 border-t border-github-border/30">
      <h2 class="section-title mb-8">历史解读文章</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <a href={`/githubbook/trending/${post.slug}/`}
             class={`glass-card p-6 card-hover animate-fade-in-up opacity-0 stagger-${Math.min(i + 1, 5)} group`}>
            <div class="text-github-muted text-xs mb-3">{post.date}</div>
            <h3 class="text-white font-semibold mb-2 group-hover:text-brand-primary transition-colors line-clamp-2">
              {post.title}
            </h3>
            <p class="text-github-muted text-sm line-clamp-2 mb-3">{post.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {post.tags?.slice(0, 3).map((tag: string) => (
                <span class="tag tag-lang text-[10px]">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
