---
---

<section class="relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-brand-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-brand-secondary/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/3 left-1/2 w-60 h-60 bg-brand-accent/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24 relative">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-primary/10
                  border border-brand-primary/20 text-brand-primary text-sm font-medium mb-6
                  animate-fade-in-up opacity-0">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"></span>
        </span>
        每日更新 · {new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-extrabold text-white leading-tight
                 animate-fade-in-up opacity-0 stagger-1 mb-6">
        追踪 <span class="gradient-text">GitHub 热点</span><br/>
        发现下一个<br class="sm:hidden" />
        <span class="gradient-text-warm">改变世界的项目</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-github-muted leading-relaxed
                animate-fade-in-up opacity-0 stagger-2 mb-8 max-w-2xl">
        每天从 GitHub Trending 精选 10 个最热开源项目，
        深度解读 AI 与前沿技术趋势，帮助开发者站在技术浪潮之巅。
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 animate-fade-in-up opacity-0 stagger-3">
        <a href="/githubbook/trending/" class="btn-primary flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          查看今日热点
        </a>
        <a href="/githubbook/ai-school/" class="btn-outline flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          AI 学堂
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 animate-fade-in-up opacity-0 stagger-4">
        {[
          { label: '每日追踪', value: 'Top 10', icon: '📊' },
          { label: '深度解读', value: 'AI 驱动', icon: '🤖' },
          { label: '技术领域', value: '全覆盖', icon: '🌐' },
          { label: '每日更新', value: '从不间断', icon: '🔄' },
        ].map((stat) => (
          <div class="glass-card p-4 text-center">
            <div class="text-2xl mb-1">{stat.icon}</div>
            <div class="text-white font-display font-bold text-lg">{stat.value}</div>
            <div class="text-github-muted text-xs">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
