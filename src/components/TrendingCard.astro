---
export interface Props {
  rank: number;
  repo: {
    owner: string;
    name: string;
    description: string;
    url: string;
    language?: string;
    languageColor?: string;
    stars: string;
    starsToday: string;
    forks: string;
    topics?: string[];
  };
  index?: number;
}

const { repo, rank, index = 0 } = Astro.props;

const languageColors: Record<string, string> = {
  Python: '#3572A5', JavaScript: '#f1e05a', TypeScript: '#3178C6',
  Rust: '#dea584', Go: '#00ADD8', Java: '#b07219', 'C++': '#f34b7d',
  'C#': '#178600', Ruby: '#701516', Swift: '#F05138',
  Kotlin: '#A97BFF', Dart: '#00B4AB', PHP: '#4F5D95',
  Shell: '#89e051', HTML: '#e34c26', CSS: '#563d7c',
  Vue: '#41b883', 'Jupyter Notebook': '#DA5B0B', default: '#8b949e',
};

const langColor = repo.languageColor || languageColors[repo.language || 'default'] || languageColors.default;

const delayClass = `stagger-${Math.min(index + 1, 5)}`;
---

<a
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  class={`glass-card p-5 block animate-fade-in-up opacity-0 ${delayClass} card-hover group`}
>
  <div class="flex items-start gap-4">
    <!-- Rank badge -->
    <div class={`flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-display font-bold text-lg
      ${rank === 1 ? 'bg-gradient-to-br from-yellow-400 to-orange-500 text-white shadow-lg shadow-yellow-500/20' :
        rank === 2 ? 'bg-gradient-to-br from-slate-400 to-slate-500 text-white shadow-lg shadow-slate-500/20' :
        rank === 3 ? 'bg-gradient-to-br from-amber-600 to-amber-700 text-white shadow-lg shadow-amber-700/20' :
        'bg-github-bg border border-github-border text-github-muted'}`}
    >
      {rank}
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap mb-1.5">
        <span class="text-white font-semibold group-hover:text-brand-primary transition-colors truncate">
          {repo.owner}/{repo.name}
        </span>
        {rank <= 3 && <span class="tag tag-hot sparkle">🔥 HOT</span>}
      </div>

      <p class="text-github-muted text-sm line-clamp-2 mb-3 leading-relaxed">
        {repo.description || '暂无描述'}
      </p>

      <div class="flex items-center gap-4 flex-wrap text-xs">
        <!-- Language -->
        {repo.language && (
          <span class="flex items-center gap-1.5 text-github-muted">
            <span class="w-2.5 h-2.5 rounded-full" style={`background-color: ${langColor}`}></span>
            {repo.language}
          </span>
        )}

        <!-- Stars total -->
        <span class="flex items-center gap-1 text-github-muted">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="opacity-70">
            <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
          </svg>
          {repo.stars}
        </span>

        <!-- Stars today -->
        <span class="flex items-center gap-1 text-brand-warm font-medium">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
          </svg>
          +{repo.starsToday} today
        </span>

        <!-- Forks -->
        <span class="flex items-center gap-1 text-github-muted">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="opacity-70">
            <path d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878zm3.75 7.378a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm3-8.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
          </svg>
          {repo.forks}
        </span>
      </div>

      <!-- Topics -->
      {repo.topics && repo.topics.length > 0 && (
        <div class="flex gap-1.5 mt-2.5 flex-wrap">
          {repo.topics.slice(0, 4).map((topic) => (
            <span class="tag tag-ai text-[10px]">{topic}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Arrow -->
    <div class="flex-shrink-0 text-github-muted group-hover:text-brand-primary group-hover:translate-x-1 transition-all">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17L17 7M17 7H7m10 0v10" />
      </svg>
    </div>
  </div>
</a>
